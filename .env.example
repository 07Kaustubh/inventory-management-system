# =============================================================================
# Inventory & Order Management System — environment variables
# Copy this file to `.env` and adjust values for your environment.
# DO NOT commit `.env` — it is gitignored by design.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# ---- Backend (FastAPI) ----
# In docker-compose this is overridden internally to use service host `db`.
# Set this only if running backend outside compose (e.g. `uvicorn` on host).
DATABASE_URL=postgresql+psycopg://inventory:change_me_in_real_env@localhost:5432/inventory_db
BACKEND_PORT=8000

# Comma-separated list of allowed origins for CORS.
# Add your deployed frontend origin here when going to production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Low-stock threshold used by the dashboard endpoint.
LOW_STOCK_THRESHOLD=10

# ---- Frontend (React + Vite) ----
# Base URL the browser should hit for the API.
# In local docker-compose, point the browser at http://localhost:8000.
# In production, set this to your deployed backend URL (e.g. https://api.example.com).
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=3000
